def count_words(text):
    words = text.split()
    word_count = {}

    for word in words:
        if word in word_count:
            word_count[word] += 1
        else:
            word_count[word] = 1

    return word_count


text =  input("Enter the sentence:  ")
result = count_words(text)

for word, count in result.items():
    print(word + ":", count)